rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && 
               data.email is string && data.email.size() <= 256 &&
               data.createdAt is timestamp;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt;

      // --- Conversations Sub-collection ---
      match /conversations/{convId} {
        function isValidConversation(data) {
          return data.userId == userId &&
                 data.title is string && data.title.size() <= 200 &&
                 data.updatedAt is timestamp &&
                 (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 10000));
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidConversation(incoming());
        allow update: if isOwner(userId) && isValidConversation(incoming()) && 
                         incoming().userId == userId;
        allow delete: if isOwner(userId);

        // --- Chat Messages Sub-collection ---
        match /messages/{messageId} {
          function isValidMessage(data) {
            return data.role in ['user', 'bot', 'system'] &&
                   data.text is string && data.text.size() <= 10000 &&
                   data.timestamp is timestamp;
          }

          allow list: if isOwner(userId);
          allow get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidMessage(incoming());
          allow delete: if isOwner(userId);
        }
      }

      // --- Chat Summary Sub-collection ---
      match /chat_summary/{docId} {
        function isValidSummary(data) {
          return data.userId == userId &&
                 data.summary is string && data.summary.size() <= 10000 &&
                 data.lastUpdated is timestamp;
        }

        allow get: if isOwner(userId);
        allow write: if isOwner(userId) && isValidSummary(incoming());
      }
    }
    // --- Workouts Collection ---
    match /workouts/{workoutId} {
      function isValidWorkout(data) {
        return data.userId is string && data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 100 &&
               data.date is timestamp &&
               data.exercises is list && data.exercises.size() <= 50 &&
               data.createdAt is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkout(incoming()) && isValidId(workoutId);
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                       isValidWorkout(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // --- Routines Collection ---
    match /routines/{routineId} {
      function isValidRoutine(data) {
        return data.userId is string && data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 100 &&
               data.exercises is list && data.exercises.size() <= 50 &&
               data.createdAt is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidRoutine(incoming()) && isValidId(routineId);
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                       isValidRoutine(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
